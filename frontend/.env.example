# Stacksmith Frontend — Environment Variables
# Copy this file to .env.local for local overrides (never commit .env.local)

# Backend API base URL.
# Leave empty to use the Vite dev-server proxy (vite.config.js → /api → localhost:5000).
# Set to your deployed backend URL in production e.g. https://api.yourdomain.com
VITE_API_URL=
